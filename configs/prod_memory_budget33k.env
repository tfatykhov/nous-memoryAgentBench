# A/B: context-budget breadth (proposed by Timur 2026-07-13).
# ALL prior runs used prod's {"total":13000,"facts":3000,...}. Diagnosis says
# failures = right fact not in the injected set (ranking); breadth raises K
# and feeds the CR serial-rule more candidates (incl. verbatim chunk lines),
# attacking the same miss-class the #559 pin could not (pin promotes the top
# of a wrong ranking; budget widens the net).
NOUS_HEARTBEAT_ENABLED=false
NOUS_SCHEDULE_ENABLED=false
NOUS_RUBRIC_OUTCOME_DETECTION_ENABLED=false
NOUS_CONTEXT_BUDGET_OVERRIDES={"total": 33000, "facts": 6000, "decisions": 3500, "identity": 2200,"user_profile": 800,"procedures": 3000}
