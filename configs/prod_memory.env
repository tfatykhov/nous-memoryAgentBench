# nous PROD memory configuration (captured from 192.168.1.141:/home/pirate/nous/.env, 2026-06-29).
# Curated to the MEMORY / RECALL / CONSOLIDATION behavior knobs only.
#
# Deliberately EXCLUDED (not recall-relevant, or infra/secret/cost/runaway risk):
#   - secrets & integrations: email/telegram/emerson-hook tokens, MCP
#   - infra/isolation (harness-owned): NOUS_AGENT_ID, NOUS_PORT, NOUS_HOST,
#     NOUS_SESSION_TIMEOUT, workspace/work-queue paths, identity prompt
#   - background machinery: heartbeat, schedule, subtask, dag, critic, rubric,
#     web search, tool-pruning/context-trim (long-conversation mgmt)
#   - generation-cost knobs (affect answer cost, not the recall mechanism):
#     NOUS_THINKING_*, NOUS_EFFORT, NOUS_MAX_TOKENS, NOUS_MAX_TURNS
# Add any of the above back if you want fuller prod fidelity.

# --- models / embeddings ---
NOUS_MODEL=claude-opus-4-8
NOUS_BACKGROUND_MODEL=claude-sonnet-4-6
NOUS_EMBEDDING_MODEL=text-embedding-3-large

# --- ingestion / write path (the big recall levers) ---
NOUS_EPISODE_CHUNKS_ENABLED=true
NOUS_EPISODE_SUMMARY_ENABLED=true
NOUS_EVENT_BUS_ENABLED=true
NOUS_FACT_EXTRACTION_ENABLED=true
NOUS_EXTRACTION_COVERAGE_BROADENED=true
NOUS_FACT_DEDUP_TIEBREAKER_ENABLED=true
NOUS_FACT_NATIVE_COSINE_THRESHOLD=0.80
NOUS_TEMPORAL_EXTRACTION_ENABLED=true
NOUS_COOCCURRENCE_LINKING_ENABLED=true
NOUS_ANTI_HALLUCINATION_PROMPT=true

# --- consolidation / sleep ---
NOUS_SLEEP_ENABLED=true
NOUS_CHUNK_CONSOLIDATION_ENABLED=true
NOUS_CONSOLIDATION_AUDIT_ENABLED=true
NOUS_COMPACTION_ENABLED=true
NOUS_PROC_CATALOG_ENABLED=true

# --- retrieval / ranking ---
NOUS_CROSS_ENCODER_ENABLED=false
NOUS_QUERY_EXPANSION_ENABLED=true
NOUS_MMR_ENABLED=false
NOUS_RRF_K=30
NOUS_RELEVANCE_FLOOR_ENABLED=true
NOUS_RELEVANCE_DROP_RATIO=0.6
NOUS_RECENCY_RESOLVER_ENABLED=true
NOUS_RESIDUAL_ACTIVATION_ENABLED=true
NOUS_RECALL_INCLUDE_PARENT_EPISODES=true
NOUS_STALENESS_PENALTY_ENABLED=true
NOUS_STALENESS_HALF_LIFE_DAYS=20

# --- admission control ---
NOUS_ADMISSION_SHADOW_MODE=false
NOUS_ADMISSION_THRESHOLD=0.60

# --- graph recall ---
NOUS_HEART_GRAPH_ALL_TYPES_ENABLED=true
NOUS_GRAPH_ADJACENCY_BOOST_ENABLED=true
NOUS_GRAPH_NEIGHBOR_SEED_SCORE_ENABLED=true
NOUS_GRAPH_HUB_AUTOSURFACE_ENABLED=true
NOUS_GRAPH_HUB_AUTOSURFACE_TOP_N=10
NOUS_GRAPH_INFERRED_EDGE_PENALTY=1.0
NOUS_GRAPH_BACKFILL_MAX_FACTS=200
NOUS_GRAPH_BACKFILL_MAX_EPISODES=200
NOUS_GRAPH_THRESHOLD_EPISODE_EPISODE=0.70
NOUS_GRAPH_THRESHOLD_CHUNK_CHUNK_CROSS=0.75
NOUS_GRAPH_THRESHOLD_CHUNK_FACT_CROSS=0.65
NOUS_CROSS_TYPE_THRESHOLD=0.70
NOUS_CROSS_TYPE_SAME_THRESHOLD=0.75
NOUS_CE_BACKFILL_ENABLED=true
NOUS_CE_BACKFILL_MIN_CONTENT_CHARS=34

# --- tinyhippo (F044) ---
NOUS_TINYHIPPO_LITE_ENABLED=true
NOUS_TINYHIPPO_CONSOLIDATED_BOOST_ENABLED=true
NOUS_TINYHIPPO_DOWNSCALE_ENABLED=false

# --- benchmark hygiene (deviates from prod) ---
# Disable PERIODIC background timers that would write reflection memories and
# spend tokens BETWEEN QA turns, confounding the memory measurement. These run
# on their own schedule independent of the benchmark turn, so they add noise
# without being part of "recall this fact". Turn-scoped capabilities the agent
# may use while answering (subtask/dag/mcp) are LEFT at prod values for fidelity.
NOUS_HEARTBEAT_ENABLED=false
NOUS_SCHEDULE_ENABLED=false
