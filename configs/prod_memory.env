# Eval config = live prod ../nous/.env  +  the overrides below.
#
# The eval nous loads ../nous/.env directly (pydantic env_file='.env'), and the
# harness passes these NOUS_* as env vars that OVERRIDE it. So the effective
# config is the FULL live prod config — model (claude-sonnet-5), critic (advised),
# effort=high, thinking=adaptive, context_window=700000, budget overrides,
# lossless capture, hybrid chunk search, date-leg, retrieval/consolidation knobs —
# ALL come from live prod .env. A pinned snapshot of that baseline is in
# configs/prod_baseline_2026-07-03.env (for reproducible A/B reference).
#
# We override ONLY the background TIMERS that would write reflection memories
# BETWEEN QA turns and confound the memory measurement (prod runs them ON):
NOUS_HEARTBEAT_ENABLED=false
NOUS_SCHEDULE_ENABLED=false

# --- A/B experiment knobs go below, one at a time, when sweeping ---
# (e.g. NOUS_EFFORT=..., NOUS_CONTEXT_BUDGET_OVERRIDES=..., NOUS_EPISODE_CHUNK_RECALL_LIMIT=...)
