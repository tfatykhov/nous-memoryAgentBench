# F086 decisive ICL arm: baseline prod config + ONLY the exemplar retrieval
# leg enabled (read path). Write-path extraction flag stays dark — the replay
# never ingests; exemplar facts come from the F086 backfill on nous_mab_icl.
NOUS_HEARTBEAT_ENABLED=false
NOUS_SCHEDULE_ENABLED=false
NOUS_RUBRIC_OUTCOME_DETECTION_ENABLED=false

# THE arm knob (top_k / cosine floor / query-length gate at nous defaults)
NOUS_EXEMPLAR_MODE_ENABLED=true

# Eval hygiene (real backstop = MAB_SESSION_TIMEOUT_BACKSTOP in the launcher).
NOUS_SESSION_TIMEOUT=86400
