# Decisive keyed-leg arm (F085 R3.3 + #564-repaired store): baseline prod config
# + ONLY the keyed retrieval leg enabled. Minimal delta vs published 0.725 —
# the sole change is exact entity-key retrieval merging (bounded K=8, score band
# 0.55) from the repaired nous_mab_wp fact store. F084 injection flags stay at
# their land-dark defaults (avoids re-introducing the -5.0pp displacement variable).
NOUS_HEARTBEAT_ENABLED=false
NOUS_SCHEDULE_ENABLED=false
NOUS_RUBRIC_OUTCOME_DETECTION_ENABLED=false

# THE arm knob (defaults: k=8, score=0.55 — kept at nous defaults)
NOUS_KEYED_FACT_LEG_ENABLED=true

# Eval hygiene (NOTE: NOUS_SESSION_TIMEOUT here is dead — harness reserves it;
# the real backstop is MAB_SESSION_TIMEOUT_BACKSTOP=86400 set by the launcher).
NOUS_SESSION_TIMEOUT=86400
