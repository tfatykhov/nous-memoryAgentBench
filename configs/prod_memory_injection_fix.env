# Injection-reliability fix stack ON (nous #559, all land-dark by default).
# Measures Layers 1-3 of the fix spec against the SAME preserved memory:
#   L1 pin: top-K direct fact hits guaranteed into pre-turn context
#   L1b render: top-N facts untruncated (200-char cap was clipping the
#      counterfactual payloads), cap raised for the rest
#   L2 lineage: superseded_by quoted with the STALE belief named (inoculation)
#   L3 backstop: deterministic recall_deep instruction when injection is empty
NOUS_HEARTBEAT_ENABLED=false
NOUS_SCHEDULE_ENABLED=false
NOUS_RUBRIC_OUTCOME_DETECTION_ENABLED=false
NOUS_FACT_PIN_TOP_K=5
NOUS_FACT_FORMAT_MAX_CHARS=600
NOUS_FACT_FORMAT_FULL_TOP_N=5
NOUS_SUPERSESSION_LINEAGE_MODE=named
NOUS_RECALL_BACKSTOP_ENABLED=true
