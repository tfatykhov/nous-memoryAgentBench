# A/B: retrieval-time cross-encoder rerank ON (F042; off in prod by design).
# CE sim (probe_ce_sim): gold@top5 0.47->0.59 overall, +11/88 on the failure
# class — the only read-path lever with a positive ceiling. This arm converts
# ceiling into an end-to-end score.
NOUS_HEARTBEAT_ENABLED=false
NOUS_SCHEDULE_ENABLED=false
