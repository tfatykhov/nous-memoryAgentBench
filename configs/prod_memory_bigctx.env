# Big-context run profile = prod_memory.env (live prod .env + timers off) PLUS a
# bounded summarizer to cut the session-end LLM burst that triggers 429s on huge
# sources (ruler_qa2_421K ~1.9M, longmemeval ~1.6M, eventqa_full ~2.3M chars).
#
# EPISODE_SUMMARY_MAX_CHUNKS: 0 (unlimited -> ~140 summary calls on a 2M-char doc)
# -> 8 (head+tail -> ~8 calls). ~15x fewer LLM calls; near-zero accuracy cost
# (lossless summarize-all only yielded a handful of facts anyway).
#
# Pair with these harness env at run time:
#   MAB_SLEEP_CYCLES=1        (3 -> 1: 3x less consolidation)
#   MAB_TURN_DELAY_S=15       (5 -> 15: pace the ~70 ingest turns)
#
# Use the FULL-fidelity prod_memory.env for the cheap slice (CR / eventqa_65536),
# which never rate-limits.
NOUS_HEARTBEAT_ENABLED=false
NOUS_SCHEDULE_ENABLED=false
NOUS_EPISODE_SUMMARY_MAX_CHUNKS=8
