# A/B experiment: FORCE spreading activation (auto-gate bypass).
# Baseline eval agents sit at density ~<=2.1, under the 3.0 auto threshold, so
# SA never fired in any published run. This config forces it ON to measure the
# post-#555/#556 spreading path (content-resolution fixes + heart-fact seeds
# default) against the SAME persisted baseline memory (nous_mab_baseline).
NOUS_HEARTBEAT_ENABLED=false
NOUS_SCHEDULE_ENABLED=false
NOUS_RUBRIC_OUTCOME_DETECTION_ENABLED=false
NOUS_SPREADING_ACTIVATION_ENABLED=true
