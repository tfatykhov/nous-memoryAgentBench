# R3v2 decisive arm: identical to prod_memory_keyedleg.env + rounds=2.
# Sole delta vs the 0.759 rounds=1 arm is the bounded iterative keyed round
# (#566): K2=8, fan-out guards 32 keys / 256 candidates (nous defaults).
NOUS_HEARTBEAT_ENABLED=false
NOUS_SCHEDULE_ENABLED=false
NOUS_RUBRIC_OUTCOME_DETECTION_ENABLED=false

NOUS_KEYED_FACT_LEG_ENABLED=true
NOUS_KEYED_FACT_LEG_ROUNDS=2

# Eval hygiene (real backstop = MAB_SESSION_TIMEOUT_BACKSTOP in the launcher).
NOUS_SESSION_TIMEOUT=86400
