# F053-remediated memory + FORCED spreading activation.
# Tests the traversal hypothesis over a graph whose episode anchor layer
# (part_of / extracted_from) has been restored by backfill_f053_episode_edges
# — yesterday's SA no-op ran over a graph the F053 prune bug had erased.
# Forced (not auto) so per-agent density vs the 3.0 gate can't confound arms.
NOUS_HEARTBEAT_ENABLED=false
NOUS_SCHEDULE_ENABLED=false
NOUS_RUBRIC_OUTCOME_DETECTION_ENABLED=false
NOUS_SPREADING_ACTIVATION_ENABLED=true
# Eval hygiene: ask-sessions must never hit the session timeout mid-replay
# (timeout sweep summarizes them -> writes episodes INTO the replay memory;
# caught 2026-07-12: +11 episodes contaminated nous_mab_baseline).
NOUS_SESSION_TIMEOUT=86400
